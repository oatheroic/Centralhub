# Gateway
GATEWAY_PORT=8080

# Inference provider: "claude" (cloud, default) or "local" (RTX 5080 / Ollama)
INFERENCE_PROVIDER=claude

# Used when INFERENCE_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Used when INFERENCE_PROVIDER=local
# host.docker.internal lets the container reach Ollama running on the host machine.
LOCAL_MODEL_BASE_URL=http://host.docker.internal:11434
LOCAL_MODEL_NAME=llama3.1

# Postgres (backs Keycloak)
POSTGRES_PASSWORD=

# Keycloak
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_REALM=centralhub
KEYCLOAK_CLIENT_ID=auth-gateway
# Must match the "secret" field in keycloak/realm-export.json (no templating
# in --import-realm) — change both together if you ever rotate it.
KEYCLOAK_CLIENT_SECRET=dev-only-change-me-auth-gateway-secret

# Auth gateway (mints/verifies our own session cookie)
AUTH_SESSION_SECRET=

# Optional: how often auth-gateway re-syncs user_roles from Keycloak's Admin
# API for every known user, so a role change made directly in Keycloak's
# console self-corrects without a manual force-logout. Defaults to 60000
# (60s) if unset — see README §8/§13.
ROLE_SYNC_INTERVAL_MS=

# --- Assets app (first third-party/self-hosted app) ---
# Own Postgres, separate from POSTGRES_PASSWORD above.
ASSETS_DB_PASSWORD=
# Shared secret auth-gateway signs data-access JWTs with; postgrest-assets
# and storage-assets verify incoming requests against the same value.
PGRST_JWT_SECRET=
# HS256 JWTs signed with PGRST_JWT_SECRET, payload {"role":"anon"} /
# {"role":"service_role"} respectively (no user claims) — storage-api's own
# fixed identity for anonymous vs. administrative calls to its API.
ASSETS_STORAGE_ANON_KEY=
ASSETS_STORAGE_SERVICE_KEY=

# --- Engineering app (second third-party/self-hosted app) ---
# Own Postgres, separate from POSTGRES_PASSWORD/ASSETS_DB_PASSWORD above.
ENGINEERING_DB_PASSWORD=
# Same HS256-JWT shape as ASSETS_STORAGE_ANON_KEY/_SERVICE_KEY above, signed
# with the same shared PGRST_JWT_SECRET.
ENGINEERING_STORAGE_ANON_KEY=
ENGINEERING_STORAGE_SERVICE_KEY=
