# Gateway
GATEWAY_PORT=8080

# Inference provider: "claude" (cloud, default) or "local" (RTX 5080 / Ollama)
INFERENCE_PROVIDER=claude

# Used when INFERENCE_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Used when INFERENCE_PROVIDER=local
# host.docker.internal lets the container reach Ollama running on the host machine.
LOCAL_MODEL_BASE_URL=http://host.docker.internal:11434
LOCAL_MODEL_NAME=llama3.1
