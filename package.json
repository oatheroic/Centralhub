{
  "name": "centralhub",
  "private": true,
  "version": "0.0.0",
  "description": "Enterprise App Factory - local-first monorepo for departmental mini-apps",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:template": "pnpm --filter @apps/template dev",
    "dev:central-hub": "pnpm --filter @apps/central-hub dev",
    "dev:marketing": "pnpm --filter @apps/marketing dev",
    "dev:finance": "pnpm --filter @apps/finance dev",
    "dev:inference-gateway": "pnpm --filter @services/inference-gateway dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "stack:up": "docker compose -f environments/docker-compose.yml --env-file environments/.env up --build",
    "stack:down": "docker compose -f environments/docker-compose.yml down",
    "stack:logs": "docker compose -f environments/docker-compose.yml logs -f"
  }
}
